{
  "id": "aliyun-sms-verify",
  "name": "阿里云短信认证服务",
  "version": "1.0.0",
  "type": "sms",
  "description": "个人认证即可使用的短信验证码服务，无需企业资质。",
  "author": {
    "name": "白猫云"
  },
  "license": "MIT",
  "homepage": "https://lxcmanager.com/",
  "requires": ">=0.2.5",
  "config": [
    {
      "key": "access_key_id",
      "label": "AccessKey ID",
      "type": "password",
      "required": true,
      "group": "阿里云凭证",
      "help": "阿里云 AccessKey ID"
    },
    {
      "key": "access_key_secret",
      "label": "AccessKey Secret",
      "type": "password",
      "required": true,
      "group": "阿里云凭证",
      "help": "阿里云 AccessKey Secret"
    },
    {
      "key": "sign_name",
      "label": "短信签名",
      "type": "text",
      "required": true,
      "group": "短信配置",
      "placeholder": "速通互联验证码",
      "help": "短信签名名称，需在阿里云控制台申请"
    },
    {
      "key": "template_code",
      "label": "模板 CODE",
      "type": "text",
      "required": true,
      "group": "短信配置",
      "placeholder": "100001",
      "help": "短信模板 CODE，需在阿里云控制台申请"
    },
    {
      "key": "scheme_name",
      "label": "方案名称",
      "type": "text",
      "required": false,
      "default": "",
      "group": "短信配置",
      "help": "认证方案名称，留空则使用默认方案"
    },
    {
      "key": "template_vars",
      "label": "额外模板变量",
      "type": "keyvalue",
      "required": false,
      "default": {
        "min": "5"
      },
      "group": "短信配置",
      "help": "短信模板中除验证码(code)外的其他变量，如有效期(min)。键值对格式。"
    },
    {
      "key": "code_length",
      "label": "验证码长度",
      "type": "select",
      "required": false,
      "default": "4",
      "group": "高级设置",
      "options": [
        {
          "value": "4",
          "label": "4 位"
        },
        {
          "value": "5",
          "label": "5 位"
        },
        {
          "value": "6",
          "label": "6 位"
        },
        {
          "value": "7",
          "label": "7 位"
        },
        {
          "value": "8",
          "label": "8 位"
        }
      ],
      "help": "验证码位数，建议 4-6 位",
      "group_collapsed": true
    },
    {
      "key": "valid_time",
      "label": "验证码有效期",
      "type": "number",
      "required": false,
      "default": 300,
      "group": "高级设置",
      "help": "验证码有效期（秒），默认 300 秒"
    },
    {
      "key": "code_type",
      "label": "验证码类型",
      "type": "select",
      "required": false,
      "default": "1",
      "group": "高级设置",
      "options": [
        {
          "value": "1",
          "label": "纯数字"
        },
        {
          "value": "2",
          "label": "大写字母"
        },
        {
          "value": "3",
          "label": "小写字母"
        },
        {
          "value": "4",
          "label": "大小写混合"
        },
        {
          "value": "5",
          "label": "数字+大写字母"
        },
        {
          "value": "6",
          "label": "数字+小写字母"
        },
        {
          "value": "7",
          "label": "数字+大小写混合"
        }
      ],
      "help": "验证码字符类型"
    }
  ]
}
